# drop2md configuration — copy to config.toml and edit
# config.toml is gitignored; this file is the committed template.

[paths]
# Folder to watch for new documents
watch_dir = "~/Documents/drop-to-md"
# Output directory for converted markdown files
output_dir = "~/Documents/markdown-output"

[pdf]
# Enable Marker (GPLv3, requires marker-pdf pip extra, Apple MPS / CUDA / CPU)
use_marker = true
# Enable Docling (Apache 2.0, requires docling pip extra, CPU-capable)
use_docling = true
# Device for Marker inference: "mps" (Apple Silicon), "cuda" (NVIDIA), "cpu"
marker_device = "mps"

[office]
# Use MarkItDown for DOCX/PPTX/XLSX (falls back to pandoc if unavailable)
use_markitdown = true

[ocr]
# Use pytesseract for image files (PNG/JPG)
enabled = true
# Tesseract language codes (e.g. "eng", "deu", "eng+deu")
language = "eng"

[ollama]
# Enable AI enhancement (image captions, table validation)
enabled = false
# Provider: "ollama" (local, free), "claude", "openai", "hf" (HuggingFace)
provider = "ollama"
# API key — blank means the SDK reads the env var (ANTHROPIC_API_KEY / OPENAI_API_KEY / HF_TOKEN)
api_key = ""
base_url = "http://localhost:11434"
# Vision-capable model (qwen3.5, minicpm-v, llava, etc.)
model = "qwen3.5:latest"
timeout_seconds = 60

# OpenAI / HuggingFace settings — used when provider = "openai" or "hf"
# [openai]
# model = "gpt-4o-mini"
# base_url = "https://api.openai.com/v1"   # set to HF router URL for provider = "hf"
# timeout_seconds = 30
# reasoning_effort = ""                    # "low" | "medium" | "high" — reasoning models only

# ── ChatGPT example (reasoning model) ────────────────────────────────────────
# [ollama]
# enabled = true
# provider = "openai"
# api_key = ""                             # or set OPENAI_API_KEY env var
#
# [openai]
# model = "gpt-5.2"
# base_url = "https://api.openai.com/v1"
# timeout_seconds = 120
# reasoning_effort = "medium"             # "low" | "medium" | "high"

# ── Gemini example ────────────────────────────────────────────────────────────
# [ollama]
# enabled = true
# provider = "openai"
# api_key = ""                             # or set OPENAI_API_KEY to your Google AI Studio key
#
# [openai]
# model = "gemini-3-pro-preview"
# base_url = "https://generativelanguage.googleapis.com/v1beta/openai/"
# timeout_seconds = 120
# reasoning_effort = ""                   # Gemini does not use reasoning_effort

# Claude settings — used when provider = "claude"
# [claude]
# model = "claude-haiku-4-5-20251001"
# timeout_seconds = 30

[output]
# Add YAML frontmatter block to each output file
add_frontmatter = true
# Subdirectory name for extracted images (relative to each output .md file)
image_subdir = "images"
# Keep <!-- Page N --> markers in output
preserve_page_markers = false
# Overwrite existing .md files (false = skip if exists)
overwrite = true

[logging]
# Log level: DEBUG, INFO, WARNING, ERROR
level = "INFO"
# Log file location (empty = stderr only)
file = "~/Library/Logs/drop2md/drop2md.log"
